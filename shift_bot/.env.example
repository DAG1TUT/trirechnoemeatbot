# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# SQLite database path (for production consider PostgreSQL URL)
DATABASE_URL=sqlite+aiosqlite:///./data/shifts.db

# Optional: comma-separated telegram_id of super-admins (override DB)
# ADMIN_IDS=123456789,987654321

# Пароль кнопки «Администратор» в Telegram-боте
# ADMIN_PASSWORD=bot_admin_secret

# Отдельный пароль входа в веб-админку (/admin/login). Если не задан — для совместимости используется ADMIN_PASSWORD.
# DASHBOARD_ADMIN_PASSWORD=web_dashboard_secret

# Секрет для cookie-сессий веб-кабинета продавца (/seller-cabinet). Обязательно в продакшене.
# SELLER_WEB_SESSION_SECRET=случайная_длинная_строка

# ─── WordPress (headless) ────────────────────────────────────────────────────
# URL вашего WordPress без слэша в конце.
# Пример для локального XAMPP/Laragon:
# WORDPRESS_URL=http://localhost/my-wp-site
#
# Пример для хостинга:
# WORDPRESS_URL=https://wp.yourdomain.ru
#
# Если переменная не задана — сайт работает со встроенными статическими данными.
WORDPRESS_URL=

# Период ISR (секунды): как часто Next.js обновляет кэш страниц.
REVALIDATE_SECONDS=60

# OpenAI API key — required for the live chat demo
OPENAI_API_KEY=sk-...

# Telegram bot for lead notifications
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Cron secret to protect /api/cron/subscriptions
CRON_SECRET=any-random-string-here

# Optional: canonical URL for metadata/OG
NEXT_PUBLIC_SITE_URL=https://your-domain.railway.app

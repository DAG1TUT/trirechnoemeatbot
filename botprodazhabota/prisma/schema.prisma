generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String   @id @default(cuid())
  apiKey       String   @unique @default(cuid())
  businessName String
  businessType String?
  systemPrompt String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Subscription
  subscriptionEndsAt DateTime?      // Дата окончания подписки (null = не задана)

  // VK integration
  vkGroupId     String?  @unique   // ID сообщества VK (число)
  vkAccessToken String?            // Ключ доступа сообщества (для отправки сообщений)
  vkConfirmCode String?            // Строка подтверждения из настроек VK Callback
  vkSecretKey   String?            // Секретный ключ из настроек VK Callback
}

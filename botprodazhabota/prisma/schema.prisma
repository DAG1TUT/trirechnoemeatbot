generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           String   @id @default(cuid())
  apiKey       String   @unique @default(cuid())
  businessName String
  businessType String?
  systemPrompt String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
